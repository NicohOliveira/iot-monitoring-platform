generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Sensor {
  id          String   @id
  name        String
  
  alerts      Alert[]
  summaries   HourlySummary[]
}

model Alert {
  id          Int      @id @default(autoincrement())
  sensorId    String
  type        String   
  message     String
  createdAt   DateTime @default(now())
  
  sensor      Sensor   @relation(fields: [sensorId], references: [id])
}

model HourlySummary {
  id          Int      @id @default(autoincrement())
  sensorId    String
  timestamp   DateTime 
  minTemp     Float
  maxTemp     Float
  avgTemp     Float
  
  sensor      Sensor   @relation(fields: [sensorId], references: [id])
}
